generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SuperAdminBP
  AdminBP
  OperatorBP
  AdminLogistik
}

enum Position {
  Sopir
  Operator
  Admin
  AdminLogistik
}

enum EmployeeStatus {
  Active
  Inactive
}

enum VehicleType {
  Mixer
  Loader
}

enum CustomerStatus {
  Active
  Inactive
}

enum TransactionStatus {
  Pending
  Confirmed
}

enum MaterialType {
  Semen
  Pasir
}

enum AggregateSourceType {
  Internal // Quarry sendiri
  External // Pembelian dari luar
}

enum AggregateType {
  SplitHalfOne // Batu Split 1/2
  SplitTwoThree // Batu Split 2/3
  Pasir // Pasir
  Other // Lainnya
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  CANCELLED
}

enum PlanStatus {
  Planned
  OnGoing
  Done
  Cancelled
}

enum PaymentMethod {
  TRANSFER
  CASH
  GIRO
  DEPOSIT
}

enum BillingAction {
  INVOICE_CREATED
  INVOICE_ISSUED
  INVOICE_CANCELLED
  PAYMENT_RECORDED
  PAYMENT_CANCELLED
  DEPOSIT_ADDED
  DEPOSIT_USED
}

model User {
  id         String     @id @default(uuid())
  username   String     @unique
  password   String
  role       Role
  employee   Employee   @relation(fields: [employeeId], references: [id])
  employeeId String     @unique
  auditLogs  AuditLog[]
}

model Employee {
  id                    String                  @id @default(uuid())
  name                  String
  position              Position
  status                EmployeeStatus          @default(Active)
  join_date             DateTime
  user                  User?
  location              Location?               @relation(fields: [locationId], references: [id])
  locationId            String?
  driver_transactions   ProductionTransaction[] @relation("SopirRelation")
  operator_transactions ProductionTransaction[] @relation("OperatorRelation")
  retase_commissions    Retase[]                @relation("DriverRetase")
}

model Location {
  id                 String                  @id @default(uuid())
  name               String                  @unique
  employees          Employee[]
  vehicles           Vehicle[]
  customers          Customer[]              @relation("CustomerOwner") // Changed
  workItems          WorkItem[]
  concreteQualities  ConcreteQuality[]
  transactions       ProductionTransaction[]
  materialIncomings  MaterialIncoming[]
  aggregateIncomings AggregateIncoming[]
  retaseSetting      RetaseSetting?
  invoices           Invoice[]
  concretePlans      ConcretePlan[]
  sharedCustomers    Customer[]              @relation("CustomerSharedLocations") // Added
  sharedProjects     Project[]               @relation("ProjectSharedLocations") // Added
  purchaseOrders     PurchaseOrder[]
}

model Vehicle {
  id           String                  @id @default(uuid())
  plate_number String                  @unique
  vehicle_type VehicleType
  code         String
  transactions ProductionTransaction[]
  location     Location                @relation(fields: [locationId], references: [id])
  locationId   String
}

model Customer {
  id            String         @id @default(uuid())
  customer_name String
  address       String // Billing Address / Alamat Tagih
  status        CustomerStatus @default(Active)

  projects Project[] // 1 Customer punya banyak Project

  location   Location @relation("CustomerOwner", fields: [locationId], references: [id]) // Changed
  locationId String

  sharedLocations Location[] @relation("CustomerSharedLocations") // Added
}

model Project {
  id               String @id @default(uuid())
  name             String // Nama Proyek
  address          String // Lokasi Proyek Pengecoran
  default_distance Float // Memindahkan default_distance dari Customer
  tax_ppn          Float // Memindahkan tax_ppn dari Customer

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  prices        ProjectPrice[] // Daftar harga per mutu untuk proyek ini
  transactions  ProductionTransaction[] // Transaksi sekarang mengarah ke Proyek
  invoices      Invoice[]
  deposits      Deposit[]
  concretePlans ConcretePlan[]

  sharedLocations Location[] @relation("ProjectSharedLocations")
}

model ProjectPrice {
  id              String          @id @default(uuid())
  project         Project         @relation(fields: [projectId], references: [id])
  projectId       String
  concreteQuality ConcreteQuality @relation(fields: [qualityId], references: [id])
  qualityId       String
  price           Float // Harga kesepakatan

  @@unique([projectId, qualityId]) // 1 Proyek hanya punya 1 harga untuk 1 mutu tertentu
}

model WorkItem {
  id            String                  @id @default(uuid())
  name          String                  @unique // e.g., Rigid, Kolom, Sloof
  transactions  ProductionTransaction[]
  concretePlans ConcretePlan[]
  location      Location                @relation(fields: [locationId], references: [id])
  locationId    String
}

model ConcreteQuality {
  id                   String                  @id @default(uuid())
  name                 String // e.g., K-225
  composition_sand     Float
  composition_stone_05 Float
  composition_stone_12 Float
  composition_stone_23 Float
  composition_cement   Float
  transactions         ProductionTransaction[]
  projectPrices        ProjectPrice[] // Added opposite relation for ProjectPrice
  concretePlans        ConcretePlan[]
  location             Location                @relation(fields: [locationId], references: [id])
  locationId           String
}

model ProductionTransaction {
  id                String            @id @default(uuid())
  date              DateTime
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id])
  vehicleId         String
  driver            Employee          @relation("SopirRelation", fields: [driverId], references: [id])
  driverId          String
  concreteQuality   ConcreteQuality   @relation(fields: [qualityId], references: [id])
  qualityId         String
  workItem          WorkItem          @relation(fields: [workItemId], references: [id])
  workItemId        String
  volume_cubic      Float
  slump             String
  project           Project           @relation(fields: [projectId], references: [id])
  projectId         String
  cumulative_volume Float
  trip_sequence     Int               @default(1)
  status            TransactionStatus @default(Pending)
  createdBy         Employee          @relation("OperatorRelation", fields: [createdById], references: [id])
  createdById       String
  location          Location          @relation(fields: [locationId], references: [id])
  locationId        String
  retase            Retase?
  invoiceItem       InvoiceItem?
}

model MaterialIncoming {
  id            String       @id @default(uuid())
  date          DateTime
  material_type MaterialType
  name          String // e.g., "Semen Tonasa", "Semen Bosowa"
  supplier      String
  tonnage       Float // Will be treated as KG
  delivery_note String
  location      Location     @relation(fields: [locationId], references: [id])
  locationId    String
}

model AggregateIncoming {
  id             String              @id @default(uuid())
  date           DateTime
  no_bon         String // No Bon / Surat Jalan
  driver_name    String // Nama Sopir
  plate_number   String // Plat Nomor Kendaraan
  volume_cubic   Float // Jumlah dalam m³
  aggregate_type AggregateType
  source_type    AggregateSourceType
  supplier       String? // Nama supplier (jika External)
  notes          String?
  location       Location            @relation(fields: [locationId], references: [id])
  locationId     String
  createdAt      DateTime            @default(now())
}

model Retase {
  id                  String                @id @default(uuid())
  transaction         ProductionTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId       String                @unique
  driver              Employee              @relation("DriverRetase", fields: [driverId], references: [id])
  driverId            String
  calculated_distance Float
  volume              Float
  price_per_cubic_km  Float
  income_amount       Float
}

model RetaseSetting {
  id                 String   @id @default(uuid())
  price_per_cubic_km Float // Harga dasar retase per kubik per kilometer
  location           Location @relation(fields: [locationId], references: [id])
  locationId         String   @unique // One setting per branch
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String // "EDIT" or "DELETE"
  entity     String // e.g., "ProductionTransaction"
  recordId   String // The ID of the affected record
  old_values String? // JSON stringified previous state
  new_values String? // JSON stringified new state (null if DELETED)
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  timestamp  DateTime @default(now())
}

// ─── INVOICE SYSTEM ────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  invoice_number String        @unique
  project        Project       @relation(fields: [projectId], references: [id])
  projectId      String
  issue_date     DateTime      @default(now())
  due_date       DateTime?
  period_start   DateTime?
  period_end     DateTime?
  status         InvoiceStatus @default(DRAFT)
  include_ppn    Boolean       @default(true)
  subtotal       Float
  tax_amount     Float         @default(0)
  total_amount   Float
  paid_amount    Float         @default(0)
  notes          String?
  cancel_reason  String? // Alasan pembatalan invoice
  cancelled_at   DateTime? // Waktu pembatalan
  items          InvoiceItem[]
  payments       Payment[]
  billingLogs    BillingLog[]
  location       Location      @relation(fields: [locationId], references: [id])
  locationId     String
  createdAt      DateTime      @default(now())
}

model InvoiceItem {
  id            String                @id @default(uuid())
  invoice       Invoice               @relation(fields: [invoiceId], references: [id])
  invoiceId     String
  transaction   ProductionTransaction @relation(fields: [transactionId], references: [id])
  transactionId String                @unique
  quantity      Float
  unit_price    Float
  subtotal      Float
}

model Payment {
  id            String        @id @default(uuid())
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  invoiceId     String
  payment_date  DateTime
  amount        Float
  method        PaymentMethod
  reference_no  String?
  proof_url     String?
  notes         String?
  is_cancelled  Boolean       @default(false) // Soft cancel
  cancel_reason String? // Alasan pembatalan
  cancelled_at  DateTime? // Waktu pembatalan
  billingLogs   BillingLog[]
  createdAt     DateTime      @default(now())
}

model Deposit {
  id          String   @id @default(uuid())
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   String
  date        DateTime @default(now())
  amount      Float
  description String
  reference   String?
  createdAt   DateTime @default(now())
}

// Immutable billing audit trail — never deleted
model BillingLog {
  id          String        @id @default(uuid())
  action      BillingAction
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id])
  invoiceId   String?
  payment     Payment?      @relation(fields: [paymentId], references: [id])
  paymentId   String?
  actorId     String
  description String
  metadata    String?
  createdAt   DateTime      @default(now())
}

// ─── PLANNING PENGECORAN ────────────────────────────────────────────────────

model ConcretePlan {
  id              String          @id @default(uuid())
  date            DateTime // Tanggal rencana pengecoran
  project         Project         @relation(fields: [projectId], references: [id])
  projectId       String
  concreteQuality ConcreteQuality @relation(fields: [qualityId], references: [id])
  qualityId       String
  workItem        WorkItem        @relation(fields: [workItemId], references: [id])
  workItemId      String
  volume_plan     Float // Volume rencana (m³)
  notes           String? // Catatan tambahan
  status          PlanStatus      @default(Planned)
  location        Location        @relation(fields: [locationId], references: [id])
  locationId      String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ─── LOGISTIK & PERALATAN ───────────────────────────────────────────────────

enum PoPaymentMethod {
  CASH
  CREDIT
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  CANCELLED
}

model PoCompanyGroup {
  id                       String             @id @default(uuid())
  name                     String
  kode_cabang              String // Singkatan untuk nomor PO, e.g. "RPJ"
  kota                     String // Kota tanda tangan
  address                  String? // Alamat KOP Surat
  email                    String?
  pimpinan_default         String? // Nama pimpinan default
  kepala_peralatan_default String? // Nama kepala peralatan default
  jabatan_kepala_default   String? // Jabatan kepala peralatan, misal: "Kepala Peralatan"
  logo_url                 String? // Path logo perusahaan untuk KOP surat
  projects                 PoCompanyProject[]
  purchaseOrders           PurchaseOrder[]
  createdAt                DateTime           @default(now())
}

model PoCompanyProject {
  id             String         @id @default(uuid())
  name           String // Nama / lokasi proyek
  kode_proyek    String? // Kode singkat opsional, e.g. "005"
  companyGroup   PoCompanyGroup @relation(fields: [companyGroupId], references: [id])
  companyGroupId String
  createdAt      DateTime       @default(now())
}

model PoCategory {
  id             String          @id @default(uuid())
  name           String
  kode_kategori  String          @unique // e.g. "ATK", "SPR", "BBM"
  require_hm_km  Boolean         @default(false)
  masterItems    MasterItem[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
}

model Supplier {
  id          String       @id @default(uuid())
  name        String
  address     String?
  contact     String?
  masterItems MasterItem[]
  createdAt   DateTime     @default(now())
}

model MasterItem {
  id          String     @id @default(uuid())
  kode_barang String     @unique
  name        String
  part_number String?
  merk        String?
  satuan      String // PCS, SET, LTR, dll
  harga       Float // Harga satuan default
  supplier    Supplier   @relation(fields: [supplierId], references: [id])
  supplierId  String
  category    PoCategory @relation(fields: [categoryId], references: [id])
  categoryId  String
  poItems     PoItem[]
  createdAt   DateTime   @default(now())
}

model PurchaseOrder {
  id             String   @id @default(uuid())
  po_number      String   @unique // Auto-generated: 001/RPJ/ATK/03/2026
  tanggal_terbit DateTime

  companyGroup     PoCompanyGroup @relation(fields: [companyGroupId], references: [id])
  companyGroupId   String
  companyProjectId String? // Opsional, tujuan/lokasi proyek

  category   PoCategory @relation(fields: [categoryId], references: [id])
  categoryId String

  supplierId String

  // Tanda tangan
  pimpinan         String // Nama pimpinan (bisa di-override dari default)
  kepala_peralatan String // Nama pemesan / kepala peralatan
  jabatan_kepala   String? // Label jabatan kepala peralatan (dinamis)
  pembuat_admin    String // Nama admin pembuat

  metode_pembayaran PoPaymentMethod @default(CREDIT)
  km_hm_kendaraan   String? // Opsional, untuk kategori SPR

  // Terikat cabang (opsional)
  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  status PurchaseOrderStatus @default(DRAFT)
  notes  String?

  items     PoItem[]
  createdAt DateTime @default(now())
}

model PoItem {
  id              String        @id @default(uuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  masterItem      MasterItem    @relation(fields: [masterItemId], references: [id])
  masterItemId    String
  quantity        Float
  harga_satuan    Float // Snapshot harga saat PO dibuat
  keterangan      String? // e.g. "Plat DT 8258 RI"
  subtotal        Float
}
