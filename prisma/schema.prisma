generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SuperAdminBP
  AdminBP
  OperatorBP
}

enum Position {
  Sopir
  Operator
  Admin
}

enum EmployeeStatus {
  Active
  Inactive
}

enum VehicleType {
  Mixer
  Loader
}

enum CustomerStatus {
  Active
  Inactive
}

enum TransactionStatus {
  Pending
  Confirmed
}

enum MaterialType {
  Semen
  Pasir
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  TRANSFER
  CASH
  GIRO
  DEPOSIT
}

enum BillingAction {
  INVOICE_CREATED
  INVOICE_ISSUED
  INVOICE_CANCELLED
  PAYMENT_RECORDED
  DEPOSIT_ADDED
  DEPOSIT_USED
}

model User {
  id         String     @id @default(uuid())
  username   String     @unique
  password   String
  role       Role
  employee   Employee   @relation(fields: [employeeId], references: [id])
  employeeId String     @unique
  auditLogs  AuditLog[]
}

model Employee {
  id                    String                  @id @default(uuid())
  name                  String
  position              Position
  status                EmployeeStatus          @default(Active)
  join_date             DateTime
  user                  User?
  location              Location?               @relation(fields: [locationId], references: [id])
  locationId            String?
  driver_transactions   ProductionTransaction[] @relation("SopirRelation")
  operator_transactions ProductionTransaction[] @relation("OperatorRelation")
  retase_commissions    Retase[]                @relation("DriverRetase")
}

model Location {
  id                String                  @id @default(uuid())
  name              String                  @unique
  employees         Employee[]
  vehicles          Vehicle[]
  customers         Customer[]
  workItems         WorkItem[]
  concreteQualities ConcreteQuality[]
  transactions      ProductionTransaction[]
  materialIncomings MaterialIncoming[]
  retaseSetting     RetaseSetting?
  invoices          Invoice[]
}

model Vehicle {
  id           String                  @id @default(uuid())
  plate_number String                  @unique
  vehicle_type VehicleType
  code         String
  transactions ProductionTransaction[]
  location     Location                @relation(fields: [locationId], references: [id])
  locationId   String
}

model Customer {
  id               String                  @id @default(uuid())
  customer_name    String
  address          String                  // Billing Address / Alamat Tagih
  status           CustomerStatus          @default(Active)

  projects         Project[]               // 1 Customer punya banyak Project
  
  location         Location                @relation(fields: [locationId], references: [id])
  locationId       String
}

model Project {
  id               String @id @default(uuid())
  name             String // Nama Proyek
  address          String // Lokasi Proyek Pengecoran
  default_distance Float // Memindahkan default_distance dari Customer
  tax_ppn          Float // Memindahkan tax_ppn dari Customer

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  prices       ProjectPrice[] // Daftar harga per mutu untuk proyek ini
  transactions ProductionTransaction[] // Transaksi sekarang mengarah ke Proyek
  invoices     Invoice[]
  deposits     Deposit[]
}

model ProjectPrice {
  id              String          @id @default(uuid())
  project         Project         @relation(fields: [projectId], references: [id])
  projectId       String
  concreteQuality ConcreteQuality @relation(fields: [qualityId], references: [id])
  qualityId       String
  price           Float // Harga kesepakatan

  @@unique([projectId, qualityId]) // 1 Proyek hanya punya 1 harga untuk 1 mutu tertentu
}

model WorkItem {
  id           String                  @id @default(uuid())
  name         String                  @unique // e.g., Rigid, Kolom, Sloof
  transactions ProductionTransaction[]
  location     Location                @relation(fields: [locationId], references: [id])
  locationId   String
}

model ConcreteQuality {
  id                   String                  @id @default(uuid())
  name                 String // e.g., K-225
  composition_sand     Float
  composition_stone_05 Float
  composition_stone_12 Float
  composition_stone_23 Float
  composition_cement   Float
  transactions         ProductionTransaction[]
  projectPrices        ProjectPrice[] // Added opposite relation for ProjectPrice
  location             Location                @relation(fields: [locationId], references: [id])
  locationId           String
}

model ProductionTransaction {
  id                String            @id @default(uuid())
  date              DateTime
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id])
  vehicleId         String
  driver            Employee          @relation("SopirRelation", fields: [driverId], references: [id])
  driverId          String
  concreteQuality   ConcreteQuality   @relation(fields: [qualityId], references: [id])
  qualityId         String
  workItem          WorkItem          @relation(fields: [workItemId], references: [id])
  workItemId        String
  volume_cubic      Float
  slump             String
  project           Project           @relation(fields: [projectId], references: [id])
  projectId         String
  cumulative_volume Float
  trip_sequence     Int               @default(1)
  status            TransactionStatus @default(Pending)
  createdBy         Employee          @relation("OperatorRelation", fields: [createdById], references: [id])
  createdById       String
  location          Location          @relation(fields: [locationId], references: [id])
  locationId        String
  retase            Retase?
  invoiceItem       InvoiceItem?
}

model MaterialIncoming {
  id            String       @id @default(uuid())
  date          DateTime
  material_type MaterialType
  name          String // e.g., "Semen Tonasa", "Semen Bosowa"
  supplier      String
  tonnage       Float // Will be treated as KG
  delivery_note String
  location      Location     @relation(fields: [locationId], references: [id])
  locationId    String
}

model Retase {
  id                  String                @id @default(uuid())
  transaction         ProductionTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId       String                @unique
  driver              Employee              @relation("DriverRetase", fields: [driverId], references: [id])
  driverId            String
  calculated_distance Float
  volume              Float
  price_per_cubic_km  Float
  income_amount       Float
}

model RetaseSetting {
  id                 String   @id @default(uuid())
  price_per_cubic_km Float // Harga dasar retase per kubik per kilometer
  location           Location @relation(fields: [locationId], references: [id])
  locationId         String   @unique // One setting per branch
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String // "EDIT" or "DELETE"
  entity     String // e.g., "ProductionTransaction"
  recordId   String // The ID of the affected record
  old_values String? // JSON stringified previous state
  new_values String? // JSON stringified new state (null if DELETED)
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  timestamp  DateTime @default(now())
}

// ─── INVOICE SYSTEM ────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  invoice_number String        @unique
  project        Project       @relation(fields: [projectId], references: [id])
  projectId      String
  issue_date     DateTime      @default(now())
  due_date       DateTime?
  period_start   DateTime?
  period_end     DateTime?
  status         InvoiceStatus @default(DRAFT)
  include_ppn    Boolean       @default(true)
  subtotal       Float
  tax_amount     Float         @default(0)
  total_amount   Float
  paid_amount    Float         @default(0)
  notes          String?
  items          InvoiceItem[]
  payments       Payment[]
  billingLogs    BillingLog[]
  location       Location      @relation(fields: [locationId], references: [id])
  locationId     String
  createdAt      DateTime      @default(now())
}

model InvoiceItem {
  id            String                @id @default(uuid())
  invoice       Invoice               @relation(fields: [invoiceId], references: [id])
  invoiceId     String
  transaction   ProductionTransaction @relation(fields: [transactionId], references: [id])
  transactionId String                @unique
  quantity      Float
  unit_price    Float
  subtotal      Float
}

model Payment {
  id           String        @id @default(uuid())
  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
  invoiceId    String
  payment_date DateTime
  amount       Float
  method       PaymentMethod
  reference_no String?
  proof_url    String?
  notes        String?
  billingLogs  BillingLog[]
  createdAt    DateTime      @default(now())
}

model Deposit {
  id          String   @id @default(uuid())
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   String
  date        DateTime @default(now())
  amount      Float
  description String
  reference   String?
  createdAt   DateTime @default(now())
}

// Immutable billing audit trail — never deleted
model BillingLog {
  id          String        @id @default(uuid())
  action      BillingAction
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id])
  invoiceId   String?
  payment     Payment?      @relation(fields: [paymentId], references: [id])
  paymentId   String?
  actorId     String
  description String
  metadata    String?
  createdAt   DateTime      @default(now())
}
