# ============================================================
# ENV PRODUCTION — TEMPLATE (JANGAN COMMIT FILE .env.production)
# Salin file ini menjadi .env.production dan isi nilai aslinya
# ============================================================

# Database — PostgreSQL yang terinstall di HOST (bukan container)
# Di Ubuntu, gunakan IP bridge Docker: 172.17.0.1 (bukan localhost/host.docker.internal)
# Dapatkan IP pasti dengan: docker network inspect bridge --format='{{range .IPAM.Config}}{{.Gateway}}{{end}}'
DATABASE_URL="postgresql://rajawali_user:GANTI_PASSWORD_KUAT@172.17.0.1:5432/rajawali_prod?schema=public"

# NextAuth - WAJIB diisi dengan string random 64 karakter
# Generate: openssl rand -base64 64
NEXTAUTH_SECRET="GANTI_DENGAN_RANDOM_STRING_64_CHARS_MINIMALNYA"
NEXTAUTH_URL="https://portal.rajawalimix.com"

# Telegram Bot (opsional, untuk notifikasi produksi)
TELEGRAM_BOT_TOKEN=isi_token_bot_telegram_disini
TELEGRAM_GROUP_ID=-100isi_group_id_disini

# Pusher (Realtime Web Notifications)
NEXT_PUBLIC_PUSHER_KEY=ganti_dengan_key_pusher
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
PUSHER_APP_ID=ganti_dengan_app_id_pusher
PUSHER_SECRET=ganti_dengan_secret_pusher

# Firebase (Push Notifications)
# Path menuju file Service Account JSON yang diletakkan di server produksi (bukan di dalam docker image)
FIREBASE_KEY_PATH=/app/secrets/rajawalimix-a619e-firebase-adminsdk-fbsvc-fd1e98619b.json
